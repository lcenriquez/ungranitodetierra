<% @page_title = "Dona" %>

<div id="page-wrapper">

<!-- Main -->
	<article id="main">

		<header class="special container">
			<span class="icon solid fa-heart"></span>
			<h2>Deja tu <strong>huella</strong></h2>
			<p>Por un mundo mejor para futuras generaciones</p>
		</header>

		<!-- One -->
			<section class="wrapper style4 container">

